{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}\"/scripts/codex/setup-direnv.sh",
            "statusMessage": "Loading direnv"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}\"/scripts/codex/wrap-bash.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}\"/scripts/codex/reprobe-direnv.sh"
          }
        ]
      }
    ]
  }
}
